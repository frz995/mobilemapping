# Base URL for panoramic images
# Option A: Cloud Storage / GitHub Pages (Predictable URLs)
# Using jsDelivr CDN for GitHub (Fast & Free)
# Note: Use underscores instead of spaces for folder names to ensure compatibility
VITE_IMAGE_BASE_URL=/MMS_PIC/

# Option B: Random URLs (ImgBB, Google Drive) -> Leave EMPTY
# VITE_IMAGE_BASE_URL=

# Metadata Source: CSV (default)
VITE_METADATA_CSV_URL=/mobilemapping/metadata.csv

# Metadata Source: GeoServer WFS (uncomment to use instead of CSV)
# URL ends with your Workspace Name (from the image: Webmap_360)
VITE_GEOSERVER_URL=http://localhost:8080/geoserver/Webmap_360
# Layer format is WorkspaceName:LayerName. 
# If you published the 'panoramas' table, it is likely 'Webmap_360:panoramas'
VITE_GEOSERVER_LAYER=Webmap_360:panoramas

# QGIS WMS for background layers
VITE_QGIS_WMS_URL=
